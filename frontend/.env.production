# 生产构建：npm run build
# 前端示例：https://www.yonghongjituan.com:4013/AGV/
#
# —— 不做反代：浏览器直连后端 —— 运维一般无需改本文件，构建即可。
# 若实际域名/端口/协议不同，只改下一行 VITE_API_BASE（不要末尾多余斜杠）。
#
# 注意：页面若为 https，接口也必须 https，否则浏览器会拦截混合内容；
#       www 与裸域不一致时算作跨域，须与下方 host 保持一致。
VITE_PUBLIC_BASE=/AGV/

# 线上后端对外端口 6715（与本地 uvicorn 默认 8000 不同）
VITE_API_BASE=https://www.yonghongjituan.com:6715/api
