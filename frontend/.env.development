# 本地开发：npm run dev
# 页面示例：http://localhost:3000/agv/
# API 走相对路径 /api，由 Vite 转发到下方地址
VITE_PUBLIC_BASE=/agv/

# 本机调试时，前端直接请求本地后端
VITE_API_BASE=http://localhost:8000/api

# 本机 AGV 后端（与线上一致可改为 6715；若你本机仍用 8000，改回 http://127.0.0.1:8000）
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# 方上「Java 编排」接口在 AgvJavaServer（默认 8001），与 Python 8000 不同；不设此项时会误把 Java 请求发到 Python（路径不存在）
VITE_JAVA_API_BASE=http://127.0.0.1:8001/api

VITE_DEV_PORT=3000
